PORT=4000
# Trace, Debug, Information, Warning, Error o Critical. Por defecto Information.
LOG_LEVEL=Information

# Si se define, POST /api/simulacion, PATCH /api/proyecciones/{id}/potencias y
# POST /api/cora/sincronizar exigen el header "X-Api-Key" con este valor.
# Si se deja vacio, esos endpoints quedan sin proteger (compatibilidad hacia atras).
API_KEY=

DATABASE_URL=postgres://caudales_user:tu_password_seguro@localhost:5432/calculo_caudales

CORA_API_URL=https://cora.cavcenergy.com/api/plants/embalselectura/embalseion/ultimos/f595b230-39b2-460e-96f2-f397e5f91f38
CORA_API_URL_LA_PERLA=
CORA_API_CANTIDAD=72
CORA_SYNC_MINUTES=10
CORA_SYNC_ON_START=true

ESCORRENTIA_COEFICIENTE=0.65
ESCORRENTIA_AREA_M2=
# Numero de Curva SCS (30-100), independiente por planta (suelo/cobertura distintos). Rango tipico bosque de montana: 70-80.
CAFETAL_CURVA_NUMERO=75
LA_PERLA_CURVA_NUMERO=75

CAFETAL_LATITUD=15.22553
CAFETAL_LONGITUD=-90.11064
LA_PERLA_LATITUD=15.640000
LA_PERLA_LONGITUD=-90.069444
